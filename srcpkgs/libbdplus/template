# Template file for 'libbdplus'
pkgname=libbdplus
version=0.1.2
revision=1
build_style=gnu-configure
hostmakedepends="pkg-config"
makedepends="libgcrypt-devel"
short_desc="Open implementation of BD+ protocol"
maintainer="Andrew Benson <abenson+void@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://www.videolan.org/developers/libbdplus.html"
distfiles="https://download.videolan.org/pub/videolan/libbdplus/${version}/libbdplus-${version}.tar.bz2"
checksum=a631cae3cd34bf054db040b64edbfc8430936e762eb433b1789358ac3d3dc80a

libbdplus-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
