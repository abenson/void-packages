# Template file for 'zeek'
pkgname=zeek
version=3.1.0
revision=1
archs="x86_64* i686* aarch64* armv7* ppc64*"
build_style=cmake
hostmakedepends="flex pkg-config python3"
makedepends="bind-devel geoip-devel libpcap-devel libressl-devel jemalloc-devel
 libkqueue-devel"
short_desc="Advanced framework for network traffic analysis"
maintainer="Andrew Benson <abenson+void@gmail.com>"
license="BSD-3-Clause"
homepage="https://www.zeek.org"
distfiles="https://www.zeek.org/downloads/zeek-${version}.tar.gz"
checksum=a31c015afddef00022d3a2c0ab9383a616b6e6954cba467eb037d16b88aaac8c
nocross="Needs to build part of itself to run, can't be built separately yet."

case "$XBPS_TARGET_MACHINE" in
	*-musl)
		makedepends+=" musl-fts-devel musl-legacy-compat"
		;;
esac

pre_configure() {
	case "$XBPS_TARGET_MACHINE" in
		*-musl)
			sed -i '/set(zeekygen/i link_libraries("-lfts")' src/zeekygen/CMakeLists.txt
		;;
	esac
}

post_install() {
	vsv bro
	vlicense COPYING
}

binpac_package() {
	short_desc+=" - protocol parser compiler"
	pkg_install() {
		vmove usr/bin/binpac
	}
}

binpac-devel_package() {
	short_desc+=" - protocol parser compiler library"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
	}
}

bro_package() {
	depends="${sourcekg}>=${version}_${revision}"
	build_style=meta
	short_desc+=" (transitional dummy package)"
}
